      "wind_speed_unit": "kmh"
    },
    "formula1": {
      "view": "weekend"
    },
    "ytmusic": {
      "auth_file": "src/modules/ytmusic/browser.json",
      "poll_interval": 5,
      "default_view": "now_playing",
      "queue_size": 5
    }
  }
}

