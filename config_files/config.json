{
  "panel_driver": "epd7in5",
  "active_module": "clock",
  "rotation": 0,
  "log_level": "INFO",
  "modules": {
    "clock": {
      "time_format": "%H:%M",
      "date_format": "%A, %d %B %Y"
    },
    "weather": {
      "town": "Monterotondo",
      "country": "Italy",
      "temperature_unit": "celsius",
      "wind_speed_unit": "kmh"
    },
    "formula1": {
      "view": "weekend"
    },
    "ytmusic": {
      "auth_file": "config_files/browser.json",
      "poll_interval": 1,
      "default_view": "now_playing",
      "queue_size": 5
    },
    "photo_gallery": {
      "change_rate": 60,
      "display_mode": "bordered",
      "web_server": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 5000
      }
    }
  }
}

